miniIcon.BackgroundColor3 = Color3.fromRGB(20,20,20)
miniIcon.TextColor3 = Color3.new(1,1,1)
miniIcon.Active = true
miniIcon.Draggable = true

-- Logic
local function collectYukibun()
    local folder = workspace:FindFirstChild("ActiveSpirits")
    if not folder then return end

    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")

    for _, v in ipairs(folder:GetDescendants()) do
        if v.Name == "YukibunFace" then
            local parent = v.Parent
            if parent and parent:IsA("Model") then
                local root = parent:FindFirstChild("HumanoidRootPart") or parent:FindFirstChildWhichIsA("BasePart")
                
                if root then
                    root.CFrame = hrp.CFrame

                    -- Freeze
                    for _, part in ipairs(parent:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.Anchored = true
                            part.AssemblyLinearVelocity = Vector3.zero
                            part.AssemblyAngularVelocity = Vector3.zero
                        end
                    end
                end
            end
        end
    end
end

toggle.MouseButton1Click:Connect(function()
    collectYukibun()
end)

minimize.MouseButton1Click:Connect(function()
    frame.Visible = false
    miniIcon.Visible = true
end)

miniIcon.MouseButton1Click:Connect(function()
    frame.Visible = true
    miniIcon.Visible = false
end)
