minimize.BackgroundColor3 = Color3.fromRGB(60,60,60)
minimize.TextColor3 = Color3.new(1,1,1)

-- Minimize Icon
local miniIcon = Instance.new("TextButton", gui)
miniIcon.Size = UDim2.new(0,50,0,50)
miniIcon.Position = UDim2.new(0,50,0.5,0)
