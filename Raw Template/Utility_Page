    Thickness       = 1,
    ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
}, TpBtn)

TpBtn.MouseButton1Click:Connect(function()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            ctx.TeleportToPlayer(p)
            TpBtn.Text = IC_TP .. "  TP: " .. p.Name
            task.delay(2, function()
                TpBtn.Text = IC_TP .. "  Teleport ke Player"
            end)
            break
        end
    end
end)
TpBtn.MouseEnter:Connect(function() Tween(TpBtn, { BackgroundTransparency = 0.08 }) end)
TpBtn.MouseLeave:Connect(function() Tween(TpBtn, { BackgroundTransparency = 0.2  }) end)

