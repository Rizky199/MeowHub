--  SPECTATOR
-- ============================================================
SectionLabel(UtilScroll, 364, "SPECTATOR")

local SpecBtn = New("TextButton", {
    Text             = IC_SPEC .. "  Spectate Player",
    Size             = UDim2.new(1, -16, 0, 32),
    Position         = UDim2.new(0, 8, 0, 384),
    BackgroundColor3 = Color3.fromRGB(10, 28, 42),
    BackgroundTransparency = 0.2,
    TextColor3       = Theme.Accent,
    TextSize         = 11,
    Font             = Enum.Font.GothamSemibold,
    BorderSizePixel  = 0,
    ZIndex           = 11,
    AutoButtonColor  = false,
}, UtilScroll)
Corner(SpecBtn, 7)
New("UIStroke", {
    Color           = Theme.AccentDim,
    Thickness       = 1,
    ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
}, SpecBtn)

local spectating = false
SpecBtn.MouseButton1Click:Connect(function()
    if spectating then
        ctx.StopSpectate()
        spectating = false
        SpecBtn.Text = IC_SPEC .. "  Spectate Player"
        Tween(SpecBtn, { BackgroundColor3 = Color3.fromRGB(10, 28, 42) })
    else
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                ctx.StartSpectate(p)
                spectating = true
                SpecBtn.Text = "Stop: " .. p.Name
                Tween(SpecBtn, { BackgroundColor3 = Color3.fromRGB(0, 34, 26) })
                break
            end
        end
    end
end)
SpecBtn.MouseEnter:Connect(function() Tween(SpecBtn, { BackgroundTransparency = 0.08 }) end)
SpecBtn.MouseLeave:Connect(function() Tween(SpecBtn, { BackgroundTransparency = 0.2  }) end)

