local function UpdateWs(speed)
    currentSpeed = speed
    WsDisplay.Text = tostring(speed)
    Tween(WsBarFill, { Size = UDim2.new(math.clamp(speed / 100, 0, 1), 0, 1, 0) })
    ctx.ApplyWalkSpeed(speed)
end
WsMinus.MouseButton1Click:Connect(function() UpdateWs(math.max(2,   currentSpeed - 4)) end)
WsPlus.MouseButton1Click:Connect(function()  UpdateWs(math.min(100, currentSpeed + 4)) end)
for _, btn in ipairs({ WsMinus, WsPlus }) do
    btn.MouseEnter:Connect(function() Tween(btn, { BackgroundColor3 = Color3.fromRGB(0, 34, 46) }) end)
    btn.MouseLeave:Connect(function() Tween(btn, { BackgroundColor3 = Color3.fromRGB(20, 20, 36) }) end)
end

