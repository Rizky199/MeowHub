}, IJCard)

New("TextLabel", {
    Text             = "Infinite Jump",
    Size             = UDim2.new(1, -80, 1, 0),
    Position         = UDim2.new(0, 34, 0, 0),
    BackgroundTransparency = 1,
    TextColor3       = Theme.TextMain,
    TextSize         = 11,
    Font             = Enum.Font.GothamSemibold,
    TextXAlignment   = Enum.TextXAlignment.Left,
    ZIndex           = 12,
}, IJCard)

local IJBtn = New("TextButton", {
    Text             = "OFF",
    Size             = UDim2.new(0, 44, 0, 22),
    Position         = UDim2.new(1, -50, 0.5, -11),
    BackgroundColor3 = Color3.fromRGB(30, 16, 20),
    TextColor3       = Color3.fromRGB(180, 60, 80),
    TextSize         = 10,
    Font             = Enum.Font.GothamBold,
    BorderSizePixel  = 0,
    ZIndex           = 13,
    AutoButtonColor  = false,
}, IJCard)
Corner(IJBtn, 11)
Stroke(IJBtn, Color3.fromRGB(80, 20, 30), 1)

local ijOn = false
IJBtn.MouseButton1Click:Connect(function()
    ijOn = not ijOn
    ctx.SetInfiniteJump(ijOn)
    if ijOn then
        IJBtn.Text = "ON"
        Tween(IJBtn,    { BackgroundColor3 = Color3.fromRGB(0, 34, 26), TextColor3 = Theme.Accent })
        Tween(IJCard,   { BackgroundColor3 = Color3.fromRGB(0, 18, 28), BackgroundTransparency = 0.15 })
        Tween(IJStroke, { Color = Theme.Accent })
    else
        IJBtn.Text = "OFF"
        Tween(IJBtn,    { BackgroundColor3 = Color3.fromRGB(30, 16, 20), TextColor3 = Color3.fromRGB(180, 60, 80) })
        Tween(IJCard,   { BackgroundColor3 = Theme.Card, BackgroundTransparency = 0.3 })
        Tween(IJStroke, { Color = Theme.Border })
    end
end)
IJBtn.MouseEnter:Connect(function()
    if not ijOn then Tween(IJBtn, { BackgroundColor3 = Color3.fromRGB(45, 20, 26) }) end
end)
IJBtn.MouseLeave:Connect(function()
    if not ijOn then Tween(IJBtn, { BackgroundColor3 = Color3.fromRGB(30, 16, 20) }) end
end)

