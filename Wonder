local function getHRP()
    local char = player.Character or player.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart")
end

local function getPortalCFrame(portal)
    if portal:IsA("BasePart") then
        return portal.CFrame
    elseif portal:IsA("Model") then
        if portal.PrimaryPart then return portal.PrimaryPart.CFrame end
        local ok, piv = pcall(function() return portal:GetPivot() end)
        if ok and piv then return piv end
        for _, d in ipairs(portal:GetDescendants()) do
            if d:IsA("BasePart") then return d.CFrame end
        end
    end
    return nil
end

-- Fungsi klik Replay
local function clickReplay()
    local PlayerGui = player:WaitForChild("PlayerGui")
    local maxWait = 30
    local elapsed = 0
    local obbyResults = nil

    StatusLabel.Text = "⏳ Menunggu Results..."

    while elapsed < maxWait do
        local ok, res = pcall(function()
            local ui = PlayerGui:FindFirstChild("PlayerUi")
            if not ui then error("no PlayerUi") end
            local popups = ui:FindFirstChild("Popups")
            if not popups then error("no Popups") end
            local results = popups:FindFirstChild("ObbyResults")
            if not results then error("no ObbyResults") end
            return results
        end)
        if ok and res then obbyResults = res break end
        task.wait(0.5)
        elapsed = elapsed + 0.5
    end

    if not obbyResults then
        StatusLabel.Text = "⚠ Results tidak muncul"
        return false
    end

    elapsed = 0
    while elapsed < maxWait do
        if obbyResults.Visible then break end
        task.wait(0.3)
        elapsed = elapsed + 0.3
    end

    if not obbyResults.Visible then
        StatusLabel.Text = "⚠ Results tidak visible"
        return false
    end

    StatusLabel.Text = "✅ Results muncul! Klik Replay..."
    task.wait(0.5)

    local replayBtn = obbyResults:FindFirstChild("ReplayButton")
    if not replayBtn then
        StatusLabel.Text = "⚠ ReplayButton tidak ditemukan"
        return false
    end

    task.wait(0.5)
    local btnPos = replayBtn.AbsolutePosition
    local btnSize = replayBtn.AbsoluteSize
    local centerX = btnPos.X + btnSize.X / 2
    local centerY = btnPos.Y + btnSize.Y / 2 + 60

    local VIM = game:GetService("VirtualInputManager")
    VIM:SendMouseMoveEvent(centerX, centerY, game)
    task.wait(0.1)
    VIM:SendMouseButtonEvent(centerX, centerY, 0, true, game, 0)
    task.wait(0.08)
    VIM:SendMouseButtonEvent(centerX, centerY, 0, false, game, 0)

    StatusLabel.Text = "🔄 Replay diklik! Menunggu reset..."
    TimerLabel.Text = "⏱  —"
    return true
end

-- Fungsi tunggu player berada di Y sekitar 63.14 lalu loop
local function waitResetAndLoop(cfg, loopFunc)
    task.spawn(function()
        StatusLabel.Text = "⏳ Menunggu spawn (Y~63)..."

        local targetY = cfg and cfg.SPAWN_Y or 63.14
        local tolerance = 3  -- toleransi ±3 studs pada Y
        local timeout = 60
        local elapsed = 0

        while elapsed < timeout and running do
            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local currentY = hrp.Position.Y
                if math.abs(currentY - targetY) <= tolerance then
                    break  -- player sudah di Y yang benar
                end
            end
            task.wait(0.3)
            elapsed = elapsed + 0.3
        end

        if not running then return end

        StatusLabel.Text = "✅ Spawn terdeteksi! Delay 2s..."
        task.wait(2)

        if not running then return end

        StatusLabel.Text = "🔄 Mulai ulang..."
        loopFunc()
    end)
end

local function doPortalTeleport(cfg, loopFunc)
    warpDone = true
    TimerLabel.Text = "⏱  0s"
    StatusLabel.Text = "Teleport ke Portal..."
    local hrp = getHRP()
    local cf = getPortalCFrame(cfg.PATH_PORTAL)
    if hrp and cf then
        hrp.CFrame = cf + Vector3.new(0, 5, 0)
    end

    task.spawn(function()
        local success = clickReplay()
        if success and running then
            waitResetAndLoop(cfg, loopFunc)
        end
    end)
end

local function waitUnpaused()
    while paused and running do task.wait(0.1) end
end

local function stopAll()
    running = false
    paused = false
    warpDone = true
    if timerThread then task.cancel(timerThread) timerThread = nil end
    if mainThread  then task.cancel(mainThread)  mainThread  = nil end
    TimerLabel.Text = "⏱  —"
    StatusLabel.Text = "Dihentikan."
    BtnStart.BackgroundColor3 = Color3.fromRGB(40, 140, 70)
    BtnStart.Text = "▶ START"
end

-- START
BtnStart.MouseButton1Click:Connect(function()
    if running then return end
    if not selectedObby then
        StatusLabel.Text = "⚠ Pilih obby dulu!"
        return
    end

    local cfg = OBBY_LIST[selectedObby]
    running = true
    paused  = false
    warpDone = false

    BtnStart.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    BtnStart.Text = "Running..."

    -- Fungsi satu putaran (dipanggil ulang tiap loop)
    local function runOneLap()
        if not running then return end
        warpDone = false

        -- Cancel thread lama jika ada
        if timerThread then task.cancel(timerThread) timerThread = nil end
        if mainThread  then task.cancel(mainThread)  mainThread  = nil end

        local startTime = os.clock()

        -- TIMER THREAD
        timerThread = task.spawn(function()
            while running and not warpDone do
                waitUnpaused()
                if not running then break end
                local elapsed = os.clock() - startTime
                local remain = math.max(0, cfg.TOTAL_TIME - elapsed)
                TimerLabel.Text = ("⏱  %ds"):format(math.ceil(remain))
                if remain <= 0 then
                    if not warpDone then doPortalTeleport(cfg, runOneLap) end
                    break
                end
                task.wait(0.5)
            end
        end)

        -- MAIN TELEPORT THREAD
        mainThread = task.spawn(function()
            -- Hapus folder ChatDev jika ada
            pcall(function()
                local chatDev = workspace:FindFirstChild("ChatDev")
                if chatDev then chatDev:Destroy() end
            end)

            -- GameStart
            local hrp = getHRP()
            hrp.CFrame = cfg.PATH_GAME_START.CFrame + Vector3.new(0, 5, 0)
            StatusLabel.Text = "GameStart ✓"
            task.wait(1)

            -- Cek apakah mode sweep folder
            if cfg.SWEEP_MODE then
                -- Ambil BasePart representatif dari sebuah object
                local function getPartFromObj(obj)
                    if obj:IsA("BasePart") then
                        return obj
                    elseif obj:IsA("Model") then
                        if obj.PrimaryPart then return obj.PrimaryPart end
                        local ok, piv = pcall(function() return obj:GetPivot() end)
                        if ok and piv then
                            -- Buat referensi dari descendant pertama
                            for _, d in ipairs(obj:GetDescendants()) do
                                if d:IsA("BasePart") then return d end
                            end
                        end
                        return obj:FindFirstChildOfClass("BasePart")
                    end
                    return nil
                end

                local function getAllItems()
                    local items = {}
                    local seen = {}
                    for _, folderName in ipairs(cfg.SWEEP_FOLDERS) do
                        -- Coba FindFirstChild biasa dulu
                        local folder = workspace:FindFirstChild(folderName)
                        -- Jika tidak ada, cari di semua children workspace
                        if not folder then
                            for _, child in ipairs(workspace:GetChildren()) do
                                if child.Name == folderName then
                                    folder = child
                                    break
                                end
                            end
                        end
                        if folder then
                            for _, child in ipairs(folder:GetChildren()) do
                                if not seen[child] then
                                    seen[child] = true
                                    local part = getPartFromObj(child)
                                    if part then
                                        table.insert(items, {obj = child, part = part, folder = folderName})
                                    end
                                end
                            end
                        end
                    end
                    return items
                end

                local function sortByDistance(items, fromPos)
                    table.sort(items, function(a, b)
                        local da = (a.part.Position - fromPos).Magnitude
                        local db = (b.part.Position - fromPos).Magnitude
                        return da < db
                    end)
                    return items
                end

                local floatActive = true

                local function stopFloat()
                    floatActive = false
                    pcall(function()
                        local hrp2 = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                        if hrp2 then
                            local bv = hrp2:FindFirstChild("SG_Float")
                            if bv then bv:Destroy() end
                        end
                    end)
                end

                -- Aktifkan float (BodyVelocity Y) selama obby berjalan
                task.spawn(function()
                    while running and not warpDone and floatActive do
                        local hrp2 = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                        if hrp2 then
                            local bv = hrp2:FindFirstChild("SG_Float")
                            if not bv then
                                bv = Instance.new("BodyVelocity")
                                bv.Name = "SG_Float"
                                bv.MaxForce = Vector3.new(0, 1e5, 0)
                                bv.Velocity = Vector3.new(0, 0, 0)
                                bv.Parent = hrp2
                            end
                            bv.Velocity = Vector3.new(0, 0.5, 0)
                        end
                        task.wait(0.05)
                    end
                    stopFloat()
                end)

                local sg10Done = false -- deklarasi di sini agar monitor dan sweep bisa akses

                -- Monitor: tunggu sg10Done flag lalu matikan float dan warp
                task.spawn(function()
                    -- Tunggu sampai sg10Done = true
                    while running and not warpDone and not sg10Done do
                        task.wait(0.2)
                    end

                    if not running or warpDone then return end

                    -- Matikan float
                    floatActive = false
                    stopFloat()
                    StatusLabel.Text = "sg10 done! Float mati. Tunggu timer..."

                    -- Tunggu timer utama habis (dari startTime, TOTAL_TIME = 80)
                    while running and not warpDone do
                        task.wait(0.5)
                    end
                end)

                -- Teleport awal ke koordinat start dulu
                do
                    local hrp = getHRP()
                    hrp.CFrame = CFrame.new(8.66, -21.43, -240.53)
                    StatusLabel.Text = "Start -> Secret Garden"
                    task.wait(1)
                end

                -- Teleport ke CheckpointNoSticker00A.CheckpointNoSticker
                do
                    local ok, cpObj = pcall(function()
                        return workspace:WaitForChild("Stickers", 5)
                            :WaitForChild("CheckpointNoSticker00A", 5)
                            :WaitForChild("CheckpointNoSticker", 5)
                    end)
                    if ok and cpObj then
                        local hrp = getHRP()
                        local cf = nil
                        -- Gunakan GetPivot() seperti Dex Explorer untuk posisi akurat
                        if cpObj:IsA("BasePart") then
                            cf = cpObj.CFrame
                        elseif cpObj:IsA("Model") then
                            local ok2, piv = pcall(function() return cpObj:GetPivot() end)
                            if ok2 and piv then
                                cf = piv
                            elseif cpObj.PrimaryPart then
                                cf = cpObj.PrimaryPart.CFrame
                            else
                                local p = cpObj:FindFirstChildOfClass("BasePart")
                                if p then cf = p.CFrame end
                            end
                        end
                        if cf then
                            hrp.CFrame = cf * CFrame.new(0, 2, 0)
                            StatusLabel.Text = "Start -> CheckpointNoSticker"
                            task.wait(1)
                        end
                    end
                end

                local visitedStickers = {} -- track sticker yang sudah dikunjungi

                while running and not warpDone and not sg10Done do
                    waitUnpaused()
                    if not running or warpDone then break end

                    local hrp = getHRP()
                    local allItems = getAllItems()

                    -- Filter: Pickups semua, Stickers hanya yang belum dikunjungi
                    local items = {}
                    for _, it in ipairs(allItems) do
                        if it.folder == "Pickups" then
                            table.insert(items, it)
                        elseif it.folder == "Stickers" and not visitedStickers[it.obj] then
                            table.insert(items, it)
                        end
                    end

                    if #items == 0 then
                        StatusLabel.Text = "Semua item selesai!"
                        task.wait(1)
                        break
                    end

                    items = sortByDistance(items, hrp.Position)

                    local countP, countS = 0, 0
                    for _, it in ipairs(items) do
                        if it.folder == "Pickups" then countP += 1
                        elseif it.folder == "Stickers" then countS += 1 end
                    end
                    StatusLabel.Text = ("P:%d S:%d | Total:%d"):format(countP, countS, #items)

                    local target = items[1]
                    if target and target.obj and target.obj.Parent then
                        local cf = nil
                        if target.obj:IsA("BasePart") then
                            cf = target.obj.CFrame
                        elseif target.obj:IsA("Model") then
                            local ok2, piv = pcall(function() return target.obj:GetPivot() end)
                            if ok2 and piv then
                                cf = piv
                            elseif target.obj.PrimaryPart then
                                cf = target.obj.PrimaryPart.CFrame
                            elseif target.part then
                                cf = target.part.CFrame
                            end
                        end
                        if cf then
                            hrp = getHRP()
                            hrp.CFrame = cf * CFrame.new(0, 2, 0)
                            StatusLabel.Text = ("-> %s [%s]"):format(target.obj.Name, target.folder)
                        end

                        -- Tandai sticker sudah dikunjungi
                        if target.folder == "Stickers" then
                            visitedStickers[target.obj] = true
                            -- Jika sudah sampai sg10, stop sweep
                            if target.obj.Name == "sg10" then
                                sg10Done = true
                                StatusLabel.Text = "sg10 reached! Sweep selesai."
                                task.wait(1)
                                break
                            end
                        end
                    end

                    task.wait(1)
                end

                if not warpDone and running then
                    hrp = getHRP()
                    local gstObj = resolvePath(cfg.PATH_GAME_STOP)
                    if gstObj then hrp.CFrame = gstObj.CFrame + Vector3.new(0, 5, 0) end
                    StatusLabel.Text = "GameStop OK - Menunggu timer..."
                    while running and not warpDone do task.wait(0.5) end
                end
                return
            end

            -- Waypoints
            for i, entry in ipairs(cfg.waypoints) do
                if not running or warpDone then break end
                waitUnpaused()
                if not running or warpDone then break end

                local pos, customDelay, isWalk
                if typeof(entry) == "Vector3" then
                    pos = entry
                    customDelay = 1
                    isWalk = false
                else
                    pos = entry.pos
                    customDelay = entry.delay or 1
                    isWalk = entry.walk or false
                end

                hrp = getHRP()
                StatusLabel.Text = ("Waypoint %d/%d"):format(i, #cfg.waypoints)

                if isWalk then
                    local char = hrp.Parent
                    local Humanoid = char and char:FindFirstChildOfClass("Humanoid")
                    if Humanoid and hrp then
                        local target = Vector3.new(pos.X, hrp.Position.Y, pos.Z)
                        local speed = Humanoid.WalkSpeed > 0 and Humanoid.WalkSpeed or 16
                        local bv = Instance.new("BodyVelocity")
                        bv.MaxForce = Vector3.new(1e5, 0, 1e5)
                        bv.Velocity = Vector3.new(0, 0, 0)
                        bv.Parent = hrp
                        local maxTime = 15
                        local elapsed = 0
                        while elapsed < maxTime do
                            if not running or warpDone then break end
                            local current = hrp.Position
                            local diff = Vector3.new(target.X - current.X, 0, target.Z - current.Z)
                            if diff.Magnitude < 2 then break end
                            local dir = diff.Unit
                            bv.Velocity = dir * speed
                            hrp.CFrame = CFrame.lookAt(hrp.CFrame.Position, hrp.CFrame.Position + dir)
                            task.wait(0.05)
                            elapsed = elapsed + 0.05
                        end
                        bv.Velocity = Vector3.new(0, 0, 0)
                        bv:Destroy()
                    end
                else
                    hrp.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
                end

                task.wait(customDelay)
            end

            if warpDone or not running then return end

            -- GameStop
            hrp = getHRP()
            hrp.CFrame = cfg.PATH_GAME_STOP.CFrame + Vector3.new(0, 5, 0)
            StatusLabel.Text = "GameStop ✓ — Menunggu timer..."

            while running and not warpDone do
                task.wait(0.5)
            end
        end)
    end

    runOneLap()
end)

